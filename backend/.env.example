APP_NAME=Мал тооллого API
APP_ENV=development
DATABASE_URL=postgresql+psycopg://USER:PASSWORD@HOST:5432/postgres?sslmode=require
CORS_ORIGINS=http://localhost:5173
JWT_SECRET=generate-a-unique-random-value-of-at-least-32-characters
ACCESS_TOKEN_MINUTES=15
REFRESH_TOKEN_DAYS=30
REFRESH_COOKIE_SECURE=false
LOGIN_WINDOW_MINUTES=15
LOGIN_MAX_FAILURES=5
LOGIN_LOCK_MINUTES=15
UPLOAD_DIR=uploads
SUPABASE_URL=https://YOUR_PROJECT.supabase.co
SUPABASE_SERVICE_ROLE_KEY=set-only-in-server-secret-manager
SUPABASE_STORAGE_BUCKET=mal-images
STORAGE_PRIVATE=true

# One-time values for `python -m app.seed`; remove after the first successful seed.
SEED_OWNER_CODE=
SEED_HORSE_CODE=
SEED_CATTLE_CODE=
SEED_SHEEP_CODE=
